# --- Server ---
PORT=4000
NODE_ENV=development

# --- CORS ---
# Comma-separated list of allowed origins (frontend URLs)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# --- Supabase ---
# Get these from your Supabase project (Project Settings → API).
# The publishable (anon) key is used together with the user's bearer token
# so that Row Level Security applies as the signed-in user.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...your-anon-key...

# Optional — only required if you add admin/maintenance endpoints that
# need to bypass RLS. Never commit this value.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role...
